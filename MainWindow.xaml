<Window x:Class="AnimePlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="AnimePlayer" Height="600" Width="900"
        Background="#1a1a1a"
        Drop="Window_Drop"
        AllowDrop="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- タイトルバー下のグレー線 -->
        <Border Grid.Row="0" Height="1" Background="#444444" VerticalAlignment="Bottom"/>
        <!-- 動画表示エリア -->
        <vlc:VideoView x:Name="VideoView" Grid.Row="1" Background="#111111"/>
        <!-- コントロールバー -->
        <Grid Grid.Row="2" Background="#2d2d2d" Height="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Slider x:Name="SeekBar"
                Grid.Row="0"
                Margin="10,8,10,0"
                Foreground="#e50914"
                Background="#555"
                Minimum="0" Maximum="100" Value="0"
                ValueChanged="SeekBar_ValueChanged"
                PreviewMouseDown="SeekBar_PreviewMouseDown"
                PreviewMouseUp="SeekBar_PreviewMouseUp"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="OpenButton" Content="📂"
                    Width="40" Height="40" Margin="5,0"
                    Background="#444" Foreground="White"
                    BorderThickness="0" FontSize="18"
                    Click="OpenButton_Click"/>
                <Button x:Name="PlayPauseButton" Content="▶"
                    Width="40" Height="40" Margin="5,0"
                    Background="#444" Foreground="White"
                    BorderThickness="0" FontSize="18"
                    Click="PlayPauseButton_Click"/>
                <Button x:Name="StopButton" Content="■"
                    Width="40" Height="40" Margin="5,0"
                    Background="#444" Foreground="White"
                    BorderThickness="0" FontSize="18"
                    ToolTip="完全停止"
                    Click="StopButton_Click"/>
                <TextBlock Text="🔊" Foreground="White"
                       VerticalAlignment="Center" Margin="10,0,5,0"
                       FontSize="16"/>
                <Slider x:Name="VolumeBar"
                    Width="80" VerticalAlignment="Center"
                    Minimum="0" Maximum="200" Value="100"
                    Foreground="#e50914"
                    ValueChanged="VolumeBar_ValueChanged"/>
                <TextBlock x:Name="TimeLabel"
                       Text="00:00 / 00:00"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       FontSize="13"/>
                <TextBlock x:Name="FileNameLabel"
                       Text=""
                       Foreground="#aaaaaa"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="15,0,10,0"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="200"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>